column datatype constraint 
id uuid Auto increment 
booking_id bigint Bigserial auto increment 
user_id bigint Not null 
store_id uuid Not null from al_stores (no delete on cascade) 
business_id uuid Not null from business (no delete on cascade) 
items jsonb Not null 
status enum(created, payment_initiated, payment_failed,  booked,  completed,  refunded) Default created 
delivery_status enum(scheduled, packing, in_transit, delivered, delivery_failed, non_deliverable) Not null default scheduled 
sub_total numeric(12, 2) Not null 
tax numeric(12, 2) Not null 
delivery_fee numeric(12, 2) Not null 
platform_fee numeric(12, 2) Not null 
grand_total numeric(12, 2) Not null 
delivery_info jsonb Not null 
payment_method varchar(64) Not null 
delivery_time varchar(32) Not null 
created_at timestamptz Not null auto 
updated_at timestamptz Not null auto update_trigger  